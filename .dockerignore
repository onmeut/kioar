# Version control
.git
.gitignore
.gitattributes

# Dependencies (installed inside container)
node_modules
.pnpm-store

# Build outputs
.next
out
dist
build
*.tsbuildinfo

# Environment files (passed via --env-file at runtime)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db
*.swp
*.swo

# Testing
coverage
.nyc_output
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
playwright-report
test-results

# Docs / misc
README.md
CHANGELOG.md
LICENSE
docs
*.md

# Local dev artifacts
tmp
temp
screenshots
.cache

# Deploy scripts (not needed inside image)
deploy.sh
weekly-cleanup.sh
docker-compose.yml
docker-compose.dev.yml

# User uploads (mounted at runtime, not baked in)
public/uploads/*
!public/uploads/.gitkeep