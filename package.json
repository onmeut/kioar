{
  "name": "kioar-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "TSX_TSCONFIG_PATH=tests/tsconfig.json node --import tsx --test \"tests/*.test.ts\"",
    "assets:icons": "tsx scripts/generate-pwa-icons.ts",
    "generate:splash": "tsx scripts/generate-splash-screens.ts",
    "db:up": "docker compose up -d postgres",
    "db:setup": "npm run db:up && npm run db:migrate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env --import tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed:plans": "node --env-file=.env --import tsx scripts/seed-plans.ts",
    "db:seed:sms": "node --env-file=.env --import tsx scripts/seed-sms-templates.ts",
    "db:seed:app-settings": "node --env-file=.env --import tsx scripts/seed-app-settings.ts",
    "db:seed:categories": "node --env-file=.env --import tsx scripts/seed-categories.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@base-ui/react": "^1.4.1",
    "@dicebear/bottts-neutral": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/vazirmatn": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@tabler/icons-react": "^3.41.1",
    "@vercel/blob": "^2.3.3",
    "advanced-cropper": "^0.18.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-jalali": "4.1.0-0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "heic2any": "^0.0.4",
    "input-otp": "^1.4.2",
    "ioredis": "^5.10.1",
    "isomorphic-dompurify": "^3.12.0",
    "lightningcss": "^1.32.0",
    "lucide-react": "^1.8.0",
    "meilisearch": "^0.58.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "19.2.5",
    "react-advanced-cropper": "^0.19.6",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.73.1",
    "react-mobile-cropper": "^0.10.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.4.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
