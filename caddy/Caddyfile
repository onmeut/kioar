# ArvanCloud CDN proxy mode:
# ArvanCloud terminates HTTPS for end-users and forwards plain HTTP to Caddy.
# Caddy reverse-proxies to the standalone Next.js server on port 80.
# TLS is provided by ArvanCloud at their edge — no ACME needed here.
#
# Required in ArvanCloud DNS panel:
#   - CDN proxy ON for the A record (cloud icon enabled)
#   - SSL mode: Flexible or Full

:80 {
	encode zstd gzip

	# Long cache for hashed Next.js static assets.
	@nextStatic path /_next/static/*
	header @nextStatic Cache-Control "public, max-age=31536000, immutable"

	# Long cache for locally-served uploads (when S3 is not configured).
	@uploads path /uploads/*
	header @uploads Cache-Control "public, max-age=31536000, immutable"

	reverse_proxy app:3000 {
		# ArvanCloud always terminates HTTPS — tell the app it arrived over HTTPS.
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-For {remote_host}
		header_up X-Real-IP {remote_host}
	}
}
