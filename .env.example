# Copy to .env and fill in real values. NEVER commit .env files.
# Generate secrets with: openssl rand -hex 64 (AUTH_SECRET) or openssl rand -base64 32 (CRON_SECRET etc.)
# Use SEPARATE OAuth app credentials for dev vs. production.

# --- Runtime [PUBLIC] --------------------------------------------------------
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0
LOG_LEVEL=debug
NEXT_PUBLIC_APP_URL=http://localhost:3000
TRUST_PROXY=false

# --- Database [SECRET] -------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/kioar

# --- Database [PUBLIC] -------------------------------------------------------
DATABASE_SSL=false
DATABASE_POOL_MAX=10
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_IDLE_TX_TIMEOUT_MS=10000

# --- Redis [SECRET] ----------------------------------------------------------
# Format: redis://:password@host:port  or  redis://host:port  (no auth)
REDIS_URL=redis://127.0.0.1:6379

# --- Auth [SECRET] -----------------------------------------------------------
# Generate with: openssl rand -hex 64
AUTH_SECRET=replace-with-openssl-rand-hex-64
# Generate with: openssl rand -base64 32
CRON_SECRET=replace-with-openssl-rand-base64-32

# --- Auth [PUBLIC] -----------------------------------------------------------
# Comma-separated E.164 phone numbers granted admin access
ADMIN_PHONE_NUMBERS=+989000000000

# --- Storage [PUBLIC] --------------------------------------------------------
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL_BASE=https://cdn.example.com/your-bucket-name

# --- Storage [SECRET] --------------------------------------------------------
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key

# --- SMS [SECRET] ------------------------------------------------------------
KAVENEGAR_API_KEY=your-kavenegar-api-key

# --- SMS [PUBLIC] ------------------------------------------------------------
KAVENEGAR_TEMPLATE=your-otp-template-name
KAVENEGAR_SENDER=your-sender-number

# --- Payments [SECRET] -------------------------------------------------------
# UUID from the Zarinpal merchant dashboard
ZARINPAL_MERCHANT_ID=00000000-0000-0000-0000-000000000000

# --- Payments [PUBLIC] -------------------------------------------------------
# Set to "true" to use the Zarinpal sandbox (test environment)
ZARINPAL_SANDBOX=true
# VAT rate as a decimal, e.g. 0.09 for 9%. 0 = no VAT.
BILLING_VAT_RATE=0

# --- Google OAuth + Calendar [SECRET] ----------------------------------------
# Create a SEPARATE OAuth 2.0 client for dev at https://console.cloud.google.com/
# Required APIs: Google Calendar API
# Authorized redirect URI: ${NEXT_PUBLIC_APP_URL}/api/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-google-oauth-client-secret

# --- Google Maps [SECRET] ----------------------------------------------------
# Server-side key for Places API. Restrict by IP in GCP console.
GOOGLE_MAPS_API_KEY=your-google-maps-server-api-key

# --- Zoom OAuth [SECRET] -----------------------------------------------------
# Create a SEPARATE Zoom OAuth app for dev at https://marketplace.zoom.us/develop/create
# App type: User-managed OAuth  Scopes: meeting:write:meeting  user:read:user
# Redirect URL: ${NEXT_PUBLIC_APP_URL}/api/oauth/zoom/callback
ZOOM_OAUTH_CLIENT_ID=your-zoom-oauth-client-id
ZOOM_OAUTH_CLIENT_SECRET=your-zoom-oauth-client-secret

# --- Meilisearch (dev only) --------------------------------------------------
# Generate master key with: openssl rand -base64 32
MEILI_HOST=http://127.0.0.1:7700
MEILI_MASTER_KEY=replace-with-openssl-rand-base64-32
